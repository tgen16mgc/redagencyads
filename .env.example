# Required for encrypted HttpOnly token session.
# Generate with: openssl rand -base64 32
SESSION_SECRET=

# Optional; default is v22.0 because it remains stable for Vercel runtime use.
META_GRAPH_VERSION=v22.0

# Optional AI providers. If missing, app still returns strict prompt fallback.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

OPENROUTER_API_KEY=
# Optional. Must be one of:
# moonshotai/kimi-k2.6:free
# openrouter/owl-alpha
# nvidia/nemotron-3-super-120b-a12b:free
# When OpenRouter is used, Kimi is always tried first; this can only choose the second fallback.
OPENROUTER_MODEL=moonshotai/kimi-k2.6:free
OPENROUTER_MODEL_TIMEOUT_MS=30000
OPENROUTER_SITE_URL=
