# Required for encrypted HttpOnly token session.
# Generate with: openssl rand -base64 32
SESSION_SECRET=

# Optional; default is v22.0 because it remains stable for Vercel runtime use.
META_GRAPH_VERSION=v22.0

# Optional Facebook Login. Required if using Login with Facebook instead of pasted tokens.
META_APP_ID=
META_APP_SECRET=
# Must exactly match the valid OAuth redirect URI configured in the Meta app.
META_OAUTH_REDIRECT_URI=

# Optional 9router AI gateway. If missing, app still returns local rule-based Verdicts/Insights.
NINEROUTER_URL=https://rx5e3m7.abc-tunnel.us/v1
NINEROUTER_KEY=
NINEROUTER_MODEL=mhyc
NINEROUTER_TIMEOUT_MS=45000
NINEROUTER_MAX_TOKENS=1800

# Required for Competitor Evidence collection.
# Public Meta Ad Library links are navigation aids and are not treated as verified evidence.
APIFY_TOKEN=
APIFY_META_ADS_ACTOR_ID=
# Optional JSON template for actor-specific input. Supported placeholders:
# "{{competitors}}", "{{libraryUrls}}", "{{startUrls}}", "{{country}}", "{{limit}}",
# "{{competitors_csv}}", "{{library_urls_csv}}"
APIFY_META_ADS_INPUT_TEMPLATE=

# Optional TikTok Apify actors.
APIFY_TIKTOK_PROFILE_ACTOR_ID=clockworks/tiktok-profile-scraper
APIFY_TIKTOK_ADS_ACTOR_ID=data_xplorer/tiktok-ads-library-fast
APIFY_TIKTOK_PROFILE_INPUT_TEMPLATE=
APIFY_TIKTOK_ADS_INPUT_TEMPLATE=
