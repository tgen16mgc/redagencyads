# Required for encrypted HttpOnly token session.
# Generate with: openssl rand -base64 32
SESSION_SECRET=

# Optional; default is v22.0 because it remains stable for Vercel runtime use.
META_GRAPH_VERSION=v22.0

# Optional Kiro AI via local 9router. If missing, app still returns local rule-based Verdicts/Insights.
NINEROUTER_URL=http://localhost:20128
NINEROUTER_KEY=
NINEROUTER_MODEL=kr/claude-sonnet-4.5-thinking-agentic
NINEROUTER_TIMEOUT_MS=45000
NINEROUTER_MAX_TOKENS=1800

# Optional competitor spy extractor.
# Competitor spy works without these in public-scrape mode. Add Apify only for external commercial Meta Ad Library scraping.
META_PUBLIC_SCRAPE_TIMEOUT_MS=45000
META_PUBLIC_SCRAPE_WAIT_MS=12000
APIFY_TOKEN=
APIFY_META_ADS_ACTOR_ID=
# Optional JSON template for actor-specific input. Supported placeholders:
# "{{competitors}}", "{{libraryUrls}}", "{{startUrls}}", "{{country}}", "{{limit}}",
# "{{competitors_csv}}", "{{library_urls_csv}}"
APIFY_META_ADS_INPUT_TEMPLATE=
